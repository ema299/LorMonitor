{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Killer Curves",
  "type": "object",
  "properties": {
    "our_deck": {"type": "string"},
    "opp_deck": {"type": "string"},
    "curves": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "profile": {"type": "string", "enum": ["fast", "typical", "slow"]},
          "type": {"type": "string"},
          "frequency": {"type": "object"},
          "critical_turn": {"type": "object"},
          "key_cards": {"type": "array", "items": {"type": "string"}},
          "sequence": {"type": "object"},
          "response": {
            "type": "object",
            "properties": {
              "format_version": {"type": "string"},
              "strategy": {"type": "string"},
              "cards": {"type": "array", "items": {"type": "string"}},
              "ink_required": {"type": "integer"},
              "turn_needed": {"type": "integer"},
              "headline": {"type": "string"},
              "core_rule": {"type": "string"},
              "priority_actions": {"type": "array", "items": {"type": "string"}},
              "what_to_avoid": {"type": "array", "items": {"type": "string"}},
              "stock_build_note": {"type": "string"},
              "off_meta_note": {"type": "string"},
              "play_draw_note": {"type": "string"},
              "failure_state": {"type": "string"}
            }
          },
          "v3_payload": {
            "type": "object",
            "properties": {
              "one_line_hook": {"type": "string"},
              "mulligan_focus": {
                "type": "array",
                "items": {"type": "string"},
                "maxItems": 2
              },
              "turn_checklist": {
                "type": "object",
                "additionalProperties": {"type": "string"},
                "maxProperties": 3
              },
              "coach_badges": {
                "type": "array",
                "items": {"type": "string"},
                "maxItems": 3
              },
              "user_copy": {
                "type": "object",
                "properties": {
                  "short": {"type": "string"},
                  "expanded": {"type": "string"}
                }
              }
            }
          },
          "self_check": {
            "type": "object",
            "properties": {
              "curve_specific": {"type": "boolean"},
              "mentions_key_card": {"type": "boolean"},
              "mentions_response_card_name": {"type": "boolean"},
              "response_by_turn": {"type": "integer"},
              "not_generic": {"type": "boolean"},
              "uses_only_prompt_cards": {"type": "boolean"}
            }
          },
          "worst_case_validated": {"type": "boolean"},
          "validation": {"type": "object"}
        },
        "required": ["id", "name", "profile", "sequence", "response"]
      }
    }
  },
  "required": ["our_deck", "opp_deck", "curves"]
}
